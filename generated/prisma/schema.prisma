// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  // Placeholder for Prisma CLI validation only — runtime uses Turso via adapter in src/server/db.ts
  url      = "file:./dev.db"
}

// Necessary for Next auth
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int?

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                      String                @id @default(cuid())
  name                    String?
  email                   String?               @unique
  emailVerified           DateTime?
  image                   String?
  clearOnCheck            Boolean               @default(false)
  useGeminiPrices         Boolean               @default(true)
  collapseCompletedStores Boolean               @default(false)
  isGuest                 Boolean               @default(false)
  themeColor              String                @default("pink")
  accounts                Account[]
  sessions                Session[]
  stores                  Store[]
  shoppingListItems       ShoppingListItem[]
  favoriteItems           FavoriteGroceryItem[]
}

model Store {
  id                String             @id @default(cuid())
  userId            String
  name              String
  address           String
  placeId           String
  lat               Float
  lng               Float
  website           String?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  shoppingListItems ShoppingListItem[]

  @@unique([userId, placeId])
}

model ShoppingListItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  storeId   String?
  checked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
}

model Product {
  id                String             @id @default(cuid())
  name              String
  shoppingListItems ShoppingListItem[]

  @@index([name])
}

model FavoriteGroceryItem {
  id        String   @id @default(cuid())
  userId    String
  text      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, text])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
